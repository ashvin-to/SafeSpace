# SafeSpace AI Configuration

# API Endpoints
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Authentication (when implemented)
# NEXT_PUBLIC_AUTH_DOMAIN=auth.safespace.ai
# NEXT_PUBLIC_AUTH_CLIENT_ID=client_xxx
# NEXT_PUBLIC_AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Maps & Location (when implemented)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk_xxx
# NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/dark-v11

# Analytics (when implemented)
# NEXT_PUBLIC_ANALYTICS_ID=xxx

# Feature Flags
NEXT_PUBLIC_ENABLE_VOICE_SOS=true
NEXT_PUBLIC_ENABLE_LIVE_TRACKING=true
NEXT_PUBLIC_ENABLE_PREDICTIVE_ZONES=false
